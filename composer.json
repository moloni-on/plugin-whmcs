{
  "name": "moloni-on/whmcs",
  "description": "Moloni ON addon module for WHMCS - syncs WHMCS orders into Moloni ON as invoices/documents",
  "license": "proprietary",
  "type": "project",
  "authors": [
    {
      "name": "Moloni",
      "email": "suporte@molonion.pt"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "psr/log": "^1.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "MoloniOn\\": "src/MoloniOn/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MoloniOn\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "build": "bash build.sh",
    "build:install": "bash build.sh --install"
  },
  "scripts-descriptions": {
    "build": "Fresh prod (no-dev) install, then package the addon into dist/moloni_on.zip.",
    "build:install": "Alias of build (kept for compatibility): prod install + package."
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "7.4.33"
    }
  }
}
